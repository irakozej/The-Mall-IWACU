# Copy this file to `.env.local` and fill in the values.
# See SUPABASE.md for where to find them.

# Optional — enables the live, real-time booking flow.
# Without these, the page falls back to data/bookings.json (no live blocking).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional — for testing the GitHub-Pages build locally.
# Leave blank for plain `localhost:3000` dev.
NEXT_PUBLIC_BASE_PATH=
NEXT_PUBLIC_SITE_URL=
